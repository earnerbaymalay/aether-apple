# Auto-detect text files and normalize line endings
* text=auto

*.sh text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.properties text eol=lf
*.pro text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.txt text eol=lf
*.css text eol=lf

*.png binary
*.jpg binary
*.gif binary
*.webp binary
*.svg binary
